    <a href="https://linkedin.com/in/pavelgomez1509" target="_blank" class="post-card reveal reveal-delay-1" style="padding: 32px; display: flex; flex-direction: column; justify-content: space-between; min-height: 180px;">
      <div>
        <span style="font-family: var(--font-mono); font-size: 0.7rem; color: #0077b5; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;">Professional Net</span>
        <h3 style="font-family: var(--font-serif); font-size: 1.4rem; margin-top: 8px; color: var(--ink);">LinkedIn</h3>
        <p style="font-size: 0.85rem; color: var(--muted); margin-top: 8px;">Trayectoria profesional, networking y gestión de infraestructura de servidores.</p>
      </div>
      <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--tiger); font-weight: bold; align-self: flex-end; margin-top: 12px;">Conectar ↗</span>
    </a>

    <a href="https://github.com/elcyberchefpro" target="_blank" class="post-card reveal reveal-delay-2" style="padding: 32px; display: flex; flex-direction: column; justify-content: space-between; min-height: 180px;">
      <div>
        <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--slate); font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;">Code Repositories</span>
        <h3 style="font-family: var(--font-serif); font-size: 1.4rem; margin-top: 8px; color: var(--ink);">GitHub</h3>
        <p style="font-size: 0.85rem; color: var(--muted); margin-top: 8px;">Mis scripts de automatización, configuraciones dotfiles y repositorios del ecosistema El Tigre.</p>
      </div>
      <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--tiger); font-weight: bold; align-self: flex-end; margin
